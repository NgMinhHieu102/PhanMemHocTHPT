@model TopicsViewModel
@{
    ViewData["Title"] = "Chủ đề";
    string TopicIcon(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "bi-folder2-open";
        var n = name.Trim().ToUpperInvariant();
        if (n.Contains("SQL") || n.Contains("CSDL") || n.Contains("DỮ LIỆU")) return "bi-database-check";
        if (n.Contains("WEB") || n.Contains("HTML") || n.Contains("CSS")) return "bi-window-sidebar";
        if (n.Contains("AN TOÀN") || n.Contains("BẢO VỆ") || n.Contains("ĐẠO ĐỨC")) return "bi-shield-check";
        if (n.Contains("HỌC MÁY") || n.Contains("MÔ PHỎNG")) return "bi-cpu";
        if (n.Contains("PYTHON") || n.Contains("LẬP TRÌNH") || n.Contains("HÀM") || n.Contains("VÒNG LẶP")) return "bi-code-square";
        if (n.Contains("ĐỒ HỌA") || n.Contains("ẢNH") || n.Contains("VIDEO")) return "bi-palette";
        return "bi-journal-bookmark";
    }
}

<div class="container py-4 py-lg-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <p class="small fw-semibold text-muted mb-1">@(Model.BrowseAllGrades ? "Kho chủ đề THPT" : "Nội dung đúng khối")</p>
            @if (Model.BrowseAllGrades)
            {
                <h1 class="h3 fw-bold mb-2">Chủ đề học tập Tin học THPT</h1>
                <p class="text-muted fw-500 mb-0">Lọc nhanh theo khối 10, 11, 12 để xem bài luyện và đề ôn phù hợp.</p>
            }
            else
            {
                <h1 class="h3 fw-bold mb-2">Chủ đề học tập khối @Model.Grade</h1>
                <p class="text-muted fw-500 mb-0">
                    Các chủ đề dưới đây được chọn theo khối của bạn. Có thể dùng bộ lọc để tham khảo nội dung khối khác khi cần ôn nối tiếp.
                </p>
            }
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4" role="tablist" aria-label="Lọc theo khối">
        <button type="button" class="topic-filter-tab topic-filter-tab-pill active" data-topic-all>
            @(Model.BrowseAllGrades ? "Tất cả khối" : $"Tất cả khối {Model.Grade}")
        </button>
        <button type="button" class="topic-filter-tab topic-filter-tab-pill" data-topic-grade-tab="10">Khối 10</button>
        <button type="button" class="topic-filter-tab topic-filter-tab-pill" data-topic-grade-tab="11">Khối 11</button>
        <button type="button" class="topic-filter-tab topic-filter-tab-pill" data-topic-grade-tab="12">Khối 12</button>
    </div>

    @if (!Model.Topics.Any())
    {
        <div class="empty-state-block">
            <span class="empty-state-icon" aria-hidden="true"><i class="bi bi-folder2-open"></i></span>
            <h2 class="h5 fw-bold">Chưa có chủ đề hoạt động</h2>
            <p class="text-muted mb-4">
                @if (Model.BrowseAllGrades)
                {
                    @:Hệ thống chưa có chủ đề để hiển thị. Hãy thêm dữ liệu trong trang quản trị hoặc khởi động lại ứng dụng để chạy seed học liệu.
                }
                else
                {
                    @:Hiện chưa có chủ đề phù hợp với khối của bạn. Vui lòng liên hệ giáo viên hoặc quay lại sau.
                }
            </p>
            <a asp-area="" asp-controller="StudentPortal" asp-action="Dashboard" class="btn btn-primary">Quay về bảng điều khiển</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var t in Model.Topics)
            {
                <div class="col-md-6 col-xl-4 topic-card-cell" data-topic-grade="@t.Grade" data-topic-card-cell>
                    <article class="card topic-card-modern h-100" data-topic-card>
                        <div class="card-body d-flex flex-column">
                            <div class="topic-emoji" aria-hidden="true"><i class="bi @TopicIcon(t.Name)"></i></div>
                            <h3 class="h6 fw-semibold mb-2">@t.Name</h3>
                            <p class="small text-muted flex-grow-1 mb-4">
                                @(string.IsNullOrWhiteSpace(t.Description)
                                    ? "Chủ đề đang được bổ sung mô tả chi tiết."
                                    : t.Description.Length > 160 ? t.Description[..157] + "..." : t.Description)
                            </p>
                            <div class="mt-auto">
                                @if (t.ExerciseCount == 0)
                                {
                                    <span class="badge rounded-pill bg-light text-muted border fw-semibold px-3 py-2">Chưa có bài luyện</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill fw-semibold px-3 py-2" style="background: var(--color-success-light); color: #065f46;">@t.ExerciseCount bài luyện</span>
                                }
                                <div class="mt-3">
                                    <a asp-area="" asp-controller="Topics" asp-action="Detail" asp-route-id="@t.Id" class="btn btn-outline-primary btn-sm fw-semibold w-100">
                                        <i class="bi bi-arrow-right-circle me-1" aria-hidden="true"></i>Xem chủ đề
                                    </a>
                                </div>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</div>
