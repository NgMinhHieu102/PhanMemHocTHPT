@{
    ViewData["Title"] = "Quyền riêng tư";
}

<div class="container py-4 py-lg-5">
    <section class="card card-no-hover">
        <div class="card-body p-4 p-lg-5">
            <span class="learning-chip mb-3">
                <i class="bi bi-shield-check" aria-hidden="true"></i>
                Thông tin hệ thống
            </span>
            <h1 class="h3 fw-bold mb-3">Quyền riêng tư</h1>
            <p class="text-muted fw-500 mb-0">
                Hệ thống chỉ sử dụng dữ liệu học tập để đăng nhập, lưu bài nộp, tính điểm, gợi ý bài luyện và thống kê tiến độ cho học sinh, giáo viên quản trị.
            </p>
        </div>
    </section>
</div>
