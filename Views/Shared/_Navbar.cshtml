@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var navClass = new Func<string, string>(key =>
        string.Equals(ctrl, key, System.StringComparison.OrdinalIgnoreCase)
            ? "nav-link active fw-semibold"
            : "nav-link");
    string displayName =
        User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
        ?? User.Identity?.Name
        ?? "";
    string initial = "";
    foreach (char ch in displayName.Trim())
    {
        if (!char.IsWhiteSpace(ch))
        {
            initial = ch.ToString().ToUpperInvariant();
            break;
        }
    }
}
<header class="navbar-main sticky-top">
    <nav class="navbar navbar-expand-lg site-navbar">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index" aria-label="Trang chủ Tin học thông minh">
                <span class="brand-logo" aria-hidden="true"><i class="bi bi-mortarboard-fill"></i></span>
                <span class="brand-text">
                    <span class="brand-name">Tin học thông minh</span>
                    <span class="brand-subtitle">THPT practice lab</span>
                </span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Mở thanh điều hướng">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center gap-lg-1">
                    <li class="nav-item">
                        <a class="@navClass("Home")" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door" aria-hidden="true"></i><span>Trang chủ</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@navClass("Topics")" asp-area="" asp-controller="Topics" asp-action="Index">
                            <i class="bi bi-journal-bookmark" aria-hidden="true"></i><span>Chủ đề</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@navClass("Coding")" asp-area="" asp-controller="Coding" asp-action="Index">
                            <i class="bi bi-code-square" aria-hidden="true"></i><span>Luyện code</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@navClass("Leaderboard")" asp-area="" asp-controller="Leaderboard" asp-action="Index">
                            <i class="bi bi-trophy" aria-hidden="true"></i><span>Bảng xếp hạng</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@navClass("StatsPortal")" asp-area="" asp-controller="StatsPortal" asp-action="Index">
                            <i class="bi bi-graph-up-arrow" aria-hidden="true"></i><span>Thống kê</span>
                        </a>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown ms-lg-2">
                            <a class="nav-link dropdown-toggle nav-user-chip fw-semibold" href="#" id="accountDropdown"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="nav-user-avatar" aria-hidden="true">@(string.IsNullOrEmpty(initial) ? "?" : initial)</span>
                                <span class="nav-user-label">@displayName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end soft-dropdown py-2" aria-labelledby="accountDropdown">
                                @if (User.IsInRole("Student"))
                                {
                                    <li>
                                        <a class="dropdown-item py-2" asp-area="" asp-controller="StudentPortal" asp-action="Dashboard">
                                            <i class="bi bi-grid-1x2 me-2" aria-hidden="true"></i>Bảng điều khiển
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-area="" asp-controller="StudentPortal" asp-action="EditProfile">
                                            <i class="bi bi-person-gear me-2" aria-hidden="true"></i>Chỉnh sửa thông tin
                                        </a>
                                    </li>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item py-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                            <i class="bi bi-kanban me-2" aria-hidden="true"></i>Trang quản trị
                                        </a>
                                    </li>
                                }
                                <li>
                                    <a class="dropdown-item py-2" asp-area="" asp-controller="Account" asp-action="ChangePassword">
                                        <i class="bi bi-shield-lock me-2" aria-hidden="true"></i>Đổi mật khẩu
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider my-2" /></li>
                                <li>
                                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="px-3 pb-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100 fw-semibold">
                                            <i class="bi bi-box-arrow-right me-1" aria-hidden="true"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                            <a class="btn btn-primary btn-sm px-3 fw-semibold" asp-area="" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-door-open me-1" aria-hidden="true"></i>Đăng nhập
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>
