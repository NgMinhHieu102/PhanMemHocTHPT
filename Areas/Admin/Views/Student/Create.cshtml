@model StudentCreateViewModel
@{ ViewData["Title"] = "Thêm học sinh"; }
<h2 class="h4 mb-3">Thêm học sinh</h2>
<form method="post">
@Html.AntiForgeryToken()
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="row g-3">
<div class="col-md-6"><label class="form-label">Họ và tên</label><input asp-for="FullName" class="form-control"/></div>
<div class="col-md-6"><label class="form-label">Email</label><input asp-for="Email" class="form-control"/></div>
<div class="col-md-6"><label class="form-label">Tên đăng nhập</label><input asp-for="Username" class="form-control"/></div>
<div class="col-md-6"><label class="form-label">Mật khẩu</label><input asp-for="Password" class="form-control"/></div>
<div class="col-md-4"><label class="form-label">Khối</label><select asp-for="Grade" asp-items="Model.GradeOptions" class="form-select"></select></div>
<div class="col-md-4"><label class="form-label">Lớp</label><select asp-for="ClassId" asp-items="Model.ClassOptions" class="form-select"><option value="">Chọn lớp</option></select></div>
<div class="col-md-4"><label class="form-label">Trạng thái</label><select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select></div>
</div>
<button class="btn btn-primary mt-3">Lưu</button>
</form>
@section Scripts{<partial name="_ValidationScriptsPartial"/>}
