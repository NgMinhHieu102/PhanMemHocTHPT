@model X.PagedList.IPagedList<StudentListItem>
@{
    ViewData["Title"] = "Quản lý học sinh";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 mb-0">Danh sách học sinh</h2>
    <a asp-action="Create" class="btn btn-primary">Thêm học sinh</a>
</div>
<table class="table table-bordered admin-table bg-white">
    <thead><tr><th>Mã HS</th><th>Họ tên</th><th>Lớp</th><th>Khối</th><th>Điểm</th><th>Trạng thái</th><th></th></tr></thead>
    <tbody>
    @if (!Model.Any())
    {
        <tr>
            <td colspan="7" class="text-center text-muted">Chưa có dữ liệu học sinh.</td>
        </tr>
    }
    @foreach(var s in Model){
        <tr>
            <td>@s.StudentCode</td><td>@s.FullName</td><td>@s.ClassName</td><td>@s.Grade</td><td>@s.TotalScore</td><td>@(s.Status=="Active"?"Hoạt động":"Không hoạt động")</td>
            <td class="text-nowrap"><a asp-action="Detail" asp-route-id="@s.Id" class="btn btn-sm btn-outline-info">Chi tiết</a> <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Sửa</a> <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline" data-confirm="Xóa học sinh này?">@Html.AntiForgeryToken()<button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button></form></td>
        </tr>
    }
    </tbody>
</table>

@if (Model.PageCount > 1)
{
    <div class="d-flex justify-content-end mt-3">
        <nav aria-label="Phân trang học sinh">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="1">Đầu</a>
                </li>
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber - 1)">Trước</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Trang @Model.PageNumber / @Model.PageCount</span>
                </li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber + 1)">Sau</a>
                </li>
                <li class="page-item @(Model.PageNumber == Model.PageCount ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@Model.PageCount">Cuối</a>
                </li>
            </ul>
        </nav>
    </div>
}
