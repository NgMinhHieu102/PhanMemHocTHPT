@model TinHocTHPT.Models.ViewModels.Admin.AiQuestionGeneratorViewModel
@{ ViewData["Title"] = "Tạo câu hỏi AI"; }
<h2 class="h4 mb-3">AI tạo câu hỏi từ nội dung bài học</h2>
@if (Model.IsSuccess)
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}
<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Chủ đề</label>
            <select asp-for="TopicId" asp-items="Model.TopicOptions" class="form-select"></select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Loại câu hỏi</label>
            <select asp-for="QuestionType" asp-items="Model.QuestionTypeOptions" class="form-select"></select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Số lượng</label>
            <input asp-for="Count" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Mức độ</label>
            <select asp-for="Difficulty" asp-items="Model.DifficultyOptions" class="form-select"></select>
        </div>
        <div class="col-12">
            <label class="form-label">Nội dung bài học</label>
            <textarea asp-for="Content" class="form-control" rows="8" placeholder="Nhập nội dung bài học hoặc đoạn văn cần tạo câu hỏi"></textarea>
        </div>
        <div class="col-12">
            <button class="btn btn-primary">Tạo câu hỏi và lưu</button>
            <a asp-action="LibraryExam" class="btn btn-outline-secondary">Tạo đề thi từ thư viện câu hỏi</a>
        </div>
    </div>
</form>
@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
