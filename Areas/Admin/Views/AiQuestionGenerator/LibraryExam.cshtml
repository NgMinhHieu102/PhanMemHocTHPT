@model TinHocTHPT.Models.ViewModels.Admin.ExamLibraryGeneratorViewModel
@{ ViewData["Title"] = "Tạo đề thi từ thư viện"; }
<h2 class="h4 mb-3">Tạo đề thi từ thư viện câu hỏi hiện có</h2>
@if (Model.IsSuccess)
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}
<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Tiêu đề đề thi</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Khối</label>
            <input asp-for="Grade" class="form-control" type="number" min="10" max="12" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Chủ đề (tùy chọn)</label>
            <select asp-for="TopicId" asp-items="Model.TopicOptions" class="form-select"></select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Mức độ (tùy chọn)</label>
            <select asp-for="Difficulty" asp-items="Model.DifficultyOptions" class="form-select"></select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Số lượng câu hỏi</label>
            <input asp-for="TotalQuestions" class="form-control" type="number" min="1" max="50" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Số câu hỏi khả dụng</label>
            <input class="form-control" value="@Model.AvailableQuestions" readonly />
        </div>
        <div class="col-12">
            <button class="btn btn-primary">Tạo đề thi</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại tạo câu hỏi AI</a>
        </div>
    </div>
</form>
@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
