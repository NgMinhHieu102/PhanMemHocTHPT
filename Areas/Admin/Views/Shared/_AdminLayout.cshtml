@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string Active(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active"
            : "nav-link";
    var isAdmin = User.IsInRole("Admin");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị Tin học thông minh</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Nunito:wght@700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-body">
    <aside class="sidebar">
        <a class="sidebar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <span class="sidebar-brand-icon"><i class="bi bi-mortarboard-fill" aria-hidden="true"></i></span>
            <span>
                <strong>Study Admin</strong>
                <small>Tin học THPT</small>
            </span>
        </a>

        <nav class="sidebar-nav" aria-label="Quản trị">
            <div class="nav-section">Tổng quan</div>
            <a class="@Active("Dashboard")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-kanban" aria-hidden="true"></i>
                <span>Dashboard</span>
            </a>

            <div class="nav-section">Người học</div>
            <a class="@Active("Student")" asp-area="Admin" asp-controller="Student" asp-action="Index">
                <i class="bi bi-people" aria-hidden="true"></i>
                <span>Học sinh</span>
            </a>
            @if (isAdmin)
            {
                <a class="@Active("Teacher")" asp-area="Admin" asp-controller="Teacher" asp-action="Index">
                    <i class="bi bi-person-badge" aria-hidden="true"></i>
                    <span>Giáo viên</span>
                </a>
            }
            <a class="@Active("Class")" asp-area="Admin" asp-controller="Class" asp-action="Index">
                <i class="bi bi-door-open" aria-hidden="true"></i>
                <span>Lớp học</span>
            </a>

            <div class="nav-section">Nội dung học tập</div>
            <a class="@Active("Topic")" asp-area="Admin" asp-controller="Topic" asp-action="Index">
                <i class="bi bi-journal-bookmark" aria-hidden="true"></i>
                <span>Chủ đề</span>
            </a>
            <a class="@Active("Exercise")" asp-area="Admin" asp-controller="Exercise" asp-action="Index">
                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                <span>Bài tập</span>
            </a>
            <a class="@Active("CodingProblem")" asp-area="Admin" asp-controller="CodingProblem" asp-action="Index">
                <i class="bi bi-code-square" aria-hidden="true"></i>
                <span>Bài luyện code</span>
            </a>
            <a class="@Active("Question")" asp-area="Admin" asp-controller="Question" asp-action="Index">
                <i class="bi bi-question-circle" aria-hidden="true"></i>
                <span>Câu hỏi</span>
            </a>
            <a class="@Active("AiQuestionGenerator")" asp-area="Admin" asp-controller="AiQuestionGenerator" asp-action="Index">
                <i class="bi bi-robot" aria-hidden="true"></i>
                <span>Tạo câu hỏi AI</span>
            </a>
            <a class="@Active("Exam")" asp-area="Admin" asp-controller="Exam" asp-action="Index">
                <i class="bi bi-card-checklist" aria-hidden="true"></i>
                <span>Đề thi</span>
            </a>

            <div class="nav-section">Theo dõi</div>
            <a class="@Active("Submission")" asp-area="Admin" asp-controller="Submission" asp-action="Index">
                <i class="bi bi-inboxes" aria-hidden="true"></i>
                <span>Bài nộp</span>
            </a>
            <a class="@Active("Stats")" asp-area="Admin" asp-controller="Stats" asp-action="Students">
                <i class="bi bi-bar-chart-line" aria-hidden="true"></i>
                <span>Thống kê</span>
            </a>
            @if (isAdmin)
            {
                <a class="@Active("Settings")" asp-area="Admin" asp-controller="Settings" asp-action="Index">
                    <i class="bi bi-sliders" aria-hidden="true"></i>
                    <span>Cấu hình</span>
                </a>
            }
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="main-header">
            <div>
                <div class="admin-eyebrow">Bảng điều phối học tập</div>
                <div class="admin-title">@ViewData["Title"]</div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="admin-date"><i class="bi bi-calendar3 me-1" aria-hidden="true"></i>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                <a asp-area="" asp-controller="Account" asp-action="ChangePassword" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-shield-lock me-1" aria-hidden="true"></i>Đổi mật khẩu
                </a>
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-box-arrow-right me-1" aria-hidden="true"></i>Đăng xuất
                    </button>
                </form>
            </div>
        </header>

        <section class="main-body">
            @RenderBody()
        </section>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await Html.PartialAsync("_Toast")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
