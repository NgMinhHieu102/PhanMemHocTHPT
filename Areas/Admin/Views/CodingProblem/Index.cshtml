@model IEnumerable<CodingProblem>
@{
    ViewData["Title"] = "Bài luyện code";
}

<div class="d-flex justify-content-between mb-3">
    <h2 class="h4 mb-0">Danh sách bài luyện code</h2>
    <a asp-action="Create" class="btn btn-primary">Thêm bài luyện code</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm theo tiêu đề/chủ đề" />
    </div>
    <div class="col-md-3">
        <select name="grade" class="form-select">
            <option value="">Tất cả khối</option>
            <option value="10" selected="@(ViewBag.Grade == 10)">Khối 10</option>
            <option value="11" selected="@(ViewBag.Grade == 11)">Khối 11</option>
            <option value="12" selected="@(ViewBag.Grade == 12)">Khối 12</option>
        </select>
    </div>
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">Tất cả trạng thái</option>
            <option value="Active" selected="@(ViewBag.Status == "Active")">Hoạt động</option>
            <option value="Inactive" selected="@(ViewBag.Status == "Inactive")">Không hoạt động</option>
        </select>
    </div>
    <div class="col-md-2 d-grid">
        <button class="btn btn-outline-primary" type="submit">Lọc</button>
    </div>
</form>

<table class="table table-bordered bg-white">
    <thead>
        <tr>
            <th>Tiêu đề</th>
            <th>Chủ đề</th>
            <th>Khối</th>
            <th>Độ khó</th>
            <th>Test</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Title</td>
                <td>@p.Topic?.Name</td>
                <td>@p.Grade</td>
                <td>@(p.Difficulty == "Easy" ? "Dễ" : p.Difficulty == "Hard" ? "Khó" : "Trung bình")</td>
                <td>@p.TestCases.Count</td>
                <td>@(p.Status == "Active" ? "Hoạt động" : "Không hoạt động")</td>
                <td class="text-nowrap">
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                    <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" data-confirm="Xóa bài luyện code này?">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
