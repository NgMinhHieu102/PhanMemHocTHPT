@model DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
}

<div class="card mb-4 study-card">
    <div class="card-body p-4">
        <div class="row align-items-center gy-3">
            <div class="col-lg-8">
                <p class="small text-muted fw-bold mb-1">Bảng điều phối học tập</p>
                <h1 class="h3 fw-bold mb-2">Theo dõi nhịp học của toàn hệ thống</h1>
                <p class="text-muted mb-0">Nắm nhanh số lượng học sinh, nội dung luyện tập và bài nộp gần đây để điều phối lớp học hiệu quả hơn.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <span class="learning-chip">
                    <i class="bi bi-activity" aria-hidden="true"></i>
                    Hoàn thành @Model.CompletionRate%
                </span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between gap-3">
                    <div>
                        <div class="small text-muted fw-semibold">Học sinh</div>
                        <div class="h3 mb-0">@Model.TotalStudents</div>
                    </div>
                    <span class="stat-icon stat-icon-students"><i class="bi bi-people-fill"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between gap-3">
                    <div>
                        <div class="small text-muted fw-semibold">Giáo viên</div>
                        <div class="h3 mb-0">@Model.TotalTeachers</div>
                    </div>
                    <span class="stat-icon stat-icon-teachers"><i class="bi bi-person-badge-fill"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between gap-3">
                    <div>
                        <div class="small text-muted fw-semibold">Bài tập</div>
                        <div class="h3 mb-0">@Model.TotalExercises</div>
                    </div>
                    <span class="stat-icon stat-icon-exercises"><i class="bi bi-pencil-square"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between gap-3">
                    <div>
                        <div class="small text-muted fw-semibold">Bài nộp</div>
                        <div class="h3 mb-0">@Model.TotalSubmissions</div>
                    </div>
                    <span class="stat-icon stat-icon-submissions"><i class="bi bi-inboxes-fill"></i></span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="card h-100">
            <div class="card-body p-4">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                    <div>
                        <h2 class="h5 fw-bold mb-1">Bài nộp trong 7 ngày</h2>
                        <p class="text-muted small mb-0">Đường biểu diễn số lượt làm bài gần đây.</p>
                    </div>
                    <span class="learning-chip"><i class="bi bi-graph-up-arrow"></i>@Model.TotalAttempts lượt</span>
                </div>
                <div class="dashboard-chart-wrap">
                    <canvas id="submissionsChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card h-100">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Nội dung đang có</h2>
                <div class="d-grid gap-3">
                    <div class="d-flex justify-content-between align-items-center p-3 rounded border bg-white">
                        <span class="fw-bold"><i class="bi bi-journal-bookmark me-2 text-primary"></i>Chủ đề</span>
                        <strong>@Model.TotalTopics</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 rounded border bg-white">
                        <span class="fw-bold"><i class="bi bi-question-circle me-2 text-primary"></i>Câu hỏi</span>
                        <strong>@Model.TotalQuestions</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 rounded border bg-white">
                        <span class="fw-bold"><i class="bi bi-door-open me-2 text-primary"></i>Lớp học</span>
                        <strong>@Model.TotalClasses</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="dashboardChartData"
     data-labels='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels))'
     data-values='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SubmissionsPerDay))'
     class="d-none"></div>

@section Scripts {
    <script src="~/js/admin-dashboard.js" asp-append-version="true"></script>
}
