@model X.PagedList.IPagedList<TinHocTHPT.Models.Entities.Exercise>
@{
    ViewData["Title"] = "Bài tập";
    var topics = ViewBag.Topics as IEnumerable<TinHocTHPT.Models.Entities.Topic> ?? Enumerable.Empty<TinHocTHPT.Models.Entities.Topic>();
    var topicId = ViewBag.TopicId as int?;
    var difficulty = ViewBag.Difficulty as string;
    var grade = ViewBag.Grade as int?;
    var search = ViewBag.Search as string;
}
<div class="d-flex justify-content-between mb-3">
    <h2 class="h4 mb-0">Danh sách bài tập</h2>
    <a asp-action="CreateEdit" class="btn btn-primary">Thêm bài tập</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@search" class="form-control" placeholder="Tìm theo tiêu đề" />
    </div>
    <div class="col-md-3">
        <select name="topicId" class="form-select">
            <option value="">-- Tất cả chủ đề --</option>
            @foreach (var t in topics)
            {
                <option value="@t.Id" selected="@(topicId == t.Id)">@t.Name (Khối @t.Grade)</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="grade" class="form-select">
            <option value="">Tất cả khối</option>
            <option value="10" selected="@(grade == 10)">Khối 10</option>
            <option value="11" selected="@(grade == 11)">Khối 11</option>
            <option value="12" selected="@(grade == 12)">Khối 12</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="difficulty" class="form-select">
            <option value="">Tất cả độ khó</option>
            <option value="Easy" selected="@(difficulty == "Easy")">Dễ</option>
            <option value="Medium" selected="@(difficulty == "Medium")">Trung bình</option>
            <option value="Hard" selected="@(difficulty == "Hard")">Khó</option>
        </select>
    </div>
    <div class="col-md-1 d-grid">
        <button type="submit" class="btn btn-primary">Lọc</button>
    </div>
    <div class="col-md-2 d-grid">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Bỏ lọc</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-bordered bg-white">
        <thead>
            <tr>
                <th>Tiêu đề</th>
                <th>Chủ đề</th>
                <th>Khối</th>
                <th>Mức độ</th>
                <th>Thời gian</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted">Không có bài tập nào.</td></tr>
            }
            @foreach(var e in Model)
            {
                <tr>
                    <td>@e.Title</td>
                    <td>@e.Topic?.Name</td>
                    <td>@e.Grade</td>
                    <td>@(e.Difficulty=="Easy"?"Dễ":e.Difficulty=="Hard"?"Khó":"Trung bình")</td>
                    <td>@e.TimeLimit giây</td>
                    <td class="text-nowrap">
                        <a asp-action="CreateEdit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        <form asp-action="Delete" asp-route-id="@e.Id" method="post" class="d-inline" data-confirm="Xóa bài tập này?">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.PageCount > 1)
{
    <div class="d-flex justify-content-end mt-3">
        <nav aria-label="Phân trang bài tập">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-search="@search" asp-route-topicId="@topicId" asp-route-grade="@grade" asp-route-difficulty="@difficulty">Đầu</a>
                </li>
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber - 1)" asp-route-search="@search" asp-route-topicId="@topicId" asp-route-grade="@grade" asp-route-difficulty="@difficulty">Trước</a>
                </li>
                <li class="page-item disabled"><span class="page-link">Trang @Model.PageNumber / @Model.PageCount</span></li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber + 1)" asp-route-search="@search" asp-route-topicId="@topicId" asp-route-grade="@grade" asp-route-difficulty="@difficulty">Sau</a>
                </li>
                <li class="page-item @(Model.PageNumber == Model.PageCount ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@Model.PageCount" asp-route-search="@search" asp-route-topicId="@topicId" asp-route-grade="@grade" asp-route-difficulty="@difficulty">Cuối</a>
                </li>
            </ul>
        </nav>
    </div>
}
